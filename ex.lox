class baz {
  inbaz() {
    print "from baz";
  }
}

class hello < baz {
  inhello() {
    print "from hello";
  }
}

class world < hello {
  inworld() {
    print "from world";
  }
}

// world should inherit the methods
// from both baz and hello
var world = world();
world.inbaz();
world.inhello();
world.inworld();